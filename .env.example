# Monorepo env template — copy to `apps/web/.env` or set on your host (e.g. Railway).

# --- Web (`apps/web` / Next.js) ---
# From Clerk Dashboard → API Keys → Publishable key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Secret key: server-only (Route Handlers, webhooks, `/api/mobile/*` JWT verify). Never expose to the browser.
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: Clerk webhook signing secret for `POST /api/webhooks/clerk`
# CLERK_WEBHOOK_SECRET=whsec_...

# Optional web dev bypass (never enable in production)
# BYPASS_CLERK_AUTH=false

# --- Mobile (`apps/mobile` / Expo) — copy to `apps/mobile/.env` ---
# Same publishable key as NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Next.js base URL (LAN IP for a device, port 3101 matches default `npm run dev` for web)
# EXPO_PUBLIC_API_URL=http://127.0.0.1:3101
