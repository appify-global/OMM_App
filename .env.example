# =============================================================================
# Web — copy vars you need into apps/web/.env.local (Next.js only reads that tree).
# =============================================================================
# Clerk (browser + server): use the SAME Clerk app as sibling ../OMM_APP/.env Expo.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:3102
# BACKEND_URL=http://127.0.0.1:3102
#
# `/api/mobile/*` JWT verification (when routes run on this Next service):
# CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Support & feedback (Resend):
# RESEND_API_KEY=re_xxxxxxxx
# SUPPORT_INBOX_EMAIL=support@premarket.com.au
# RESEND_FROM_EMAIL=OMM Support <onboarding@resend.dev>

# =============================================================================
# API backend (`../OMM_BACKEND`) — optional split deploy
# =============================================================================
# DATABASE_URL, CLERK_SECRET_KEY, CLERK_WEBHOOK_SECRET, RESEND_* as appropriate.

# =============================================================================
# Expo / mobile — NOT in this repo
# =============================================================================
# Sibling repo ../OMM_APP — copy ../OMM_APP/.env.example → ../OMM_APP/.env
# EXPO_PUBLIC_* (Clerk publishable key must match NEXT_PUBLIC_* above).
