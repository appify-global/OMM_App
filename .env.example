# =============================================================================
# Web — copy to apps/web/.env.local
# =============================================================================
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:3102
# BACKEND_URL=http://127.0.0.1:3102
#
# Support & feedback email (Resend) for /api/support/* routes on Next:
# RESEND_API_KEY=re_xxxxxxxx
# SUPPORT_INBOX_EMAIL=support@premarket.com.au
# RESEND_FROM_EMAIL=OMM Support <onboarding@resend.dev>

# =============================================================================
# API backend (`../OMM_BACKEND`) — copy to that repo’s .env.example / .env.local
# =============================================================================
# DATABASE_URL, CLERK_SECRET_KEY, CLERK_WEBHOOK_SECRET, RESEND_* as needed.

# =============================================================================
# Mobile Expo — sibling repo ../OMM_APP (NOT this package root)
# =============================================================================
# See ../OMM_APP/.env.example for EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY and API/web origins.
