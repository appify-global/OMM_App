# --- Root Expo app (`app/` at repo root — expo-router / new-design) ---
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_API_URL=http://localhost:3000

# --- Monorepo: Web (`apps/web` / Next.js) — copy values to `apps/web/.env` ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CLERK_WEBHOOK_SECRET=whsec_...
# BYPASS_CLERK_AUTH=false

# --- Monorepo: Mobile (`apps/mobile` / Expo) — copy to `apps/mobile/.env` if needed ---
# Same publishable key as NEXT_PUBLIC / root Expo
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Next.js base URL (LAN IP for device; match your web dev port)
# EXPO_PUBLIC_API_URL=http://127.0.0.1:3101
