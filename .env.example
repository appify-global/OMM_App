# --- Expo app (repo root, `app/` — expo-router) ---
# Copy to `.env` at repo root for local dev.
#
# NEXT_PUBLIC_* on web and EXPO_PUBLIC_* here must use the SAME Clerk publishable key.
#
# LOCAL: Next.js listens on port 3101 by default (`apps/web/package.json`).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_API_URL=http://127.0.0.1:3101

# --- Web (`apps/web` / Next.js) — copy vars to `apps/web/.env.local` (required). ---
# Next.js only reads `.env*` inside `apps/web/`, NOT this root file.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY must equal EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY above.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Required for `/api/mobile/*` Bearer JWT verification from the Expo app:
# CLERK_SECRET_KEY matches the Clerk instance used above.
#
# Optional
# CLERK_WEBHOOK_SECRET=whsec_...
# BYPASS_CLERK_AUTH=false
