# Same Clerk app as web — must match `NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY` in `apps/web/.env`.
# If you omit this or leave the placeholder below, `app.config.js` copies the key from `apps/web/.env` when you run Expo locally (EAS builds still need this var set in secrets).
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Local: Next dev server (or LAN IP from a phone). Production / EAS: same origin as Railway, e.g.
# EXPO_PUBLIC_API_URL=https://your-service.up.railway.app
EXPO_PUBLIC_API_URL=http://127.0.0.1:3101
