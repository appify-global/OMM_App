# Copy to `.env` for local dev. Use the same Clerk publishable key as `apps/web` (Clerk Dashboard → API keys).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Base URL of the Next.js app (`apps/web`). Dev: use your machine LAN IP so a device can reach it, e.g.
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3101
# Web dev must listen on all interfaces (`next dev -H 0.0.0.0` — already set in apps/web).
EXPO_PUBLIC_API_URL=
