# Copy to `.env.local` in this folder (`apps/web`) — Next.js does NOT load the repo-root `.env`.
#
# IMPORTANT: Use the SAME values as Expo’s clerk keys in the monorepo root `.env`:
#   NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY === EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY
#
# If these differ from mobile, localhost web will hit a different Clerk instance:
# you'll see errors like “Couldn't find your account” while the user exists in another app.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional (recommended for redirects)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# CLERK_WEBHOOK_SECRET=whsec_...
# DATABASE_URL=
# BYPASS_CLERK_AUTH=false
