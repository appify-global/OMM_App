{
  "name": "unlisted-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.19.4 <26",
    "npm": ">=10"
  },
  "scripts": {
    "start": "npm run start -w apps/mobile",
    "dev:mobile": "npm run start -w apps/mobile",
    "dev:mobile:web": "npm run dev:web -w apps/mobile",
    "android": "npm run android -w apps/mobile",
    "ios": "npm run ios -w apps/mobile",
    "web": "npm run dev:web -w apps/mobile",
    "build:web": "npm run build:web -w apps/mobile",
    "start:web:prod": "serve apps/mobile/dist -s -l tcp://0.0.0.0:${PORT:-3000}",
    "dev:web": "npm run dev -w apps/web",
    "build:website": "npm run build -w apps/web",
    "start:website": "npm run start -w apps/web"
  },
  "dependencies": {
    "serve": "^14.2.6"
  }
}
